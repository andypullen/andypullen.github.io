---
title: Andy Pullen's Site
color: blue
description: The hypertext home of Andy Pullen.
---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8"/>
	<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
	<meta name="description" content="{% if snippet %}{{ snippet | striptags }}{% else %}{{ description | striptags }}{% endif %}"/>
	<link rel="stylesheet" href="{{ '/assets/css/tailwind.css' | url }}" />
	<title>{{ title }}</title>
</head>
<body class="text-{{ color }}">
	<a class="skip-link" href="#main-content">Skip to main content</a>
	<header class="w-full py-6 px-8">
		<div class="flex flex-col md:flex-row justify-between gap-4">
			<div class="flex items-center flex-1">
				<span aria-hidden="true">🧔🏻</span>
				<div class="text-2xl ml-1 font-bold">
					Andy Pullen
				</div>
			</div>
			<nav aria-label="Primary">
				<ul class="flex items-center gap-6">
					<li>
						<a href="/" {% if section === "Home" %}aria-current="page"{% endif %} class="hover:text-gray-light py-1 border-gray-light{{ ' border-b-2' if section === "Home" }}">Home</a>
					</li>
					<li>
						<a href="/benediction" {% if section === "Benediction" %}aria-current="page"{% endif %} class="hover:text-gray-light py-1 border-gray-light{{ ' border-b-2' if section === "Benediction" }}">Benediction iOS App</a>
					</li>
					{# <li>
						<a href="/blog" {% if section === "Blog" %}aria-current="page"{% endif %} class="hover:text-gray-light py-1 border-gray-light{{ ' border-b-2' if section === "Blog" }}">Blog</a>
					</li> #}
					<li>
						<a rel="me" aria-label="Find me on Mastodon" class="text-gray hover:text-gray-light py-1 border-gray-light" href="https://mastodon.social/@ajp">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
								<title>Find me on Mastodon</title>
								<path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
								<path d="M18.648 15.254c-1.816 1.763 -6.648 1.626 -6.648 1.626a18.262 18.262 0 0 1 -3.288 -.256c1.127 1.985 4.12 2.81 8.982 2.475c-1.945 2.013 -13.598 5.257 -13.668 -7.636l-.026 -1.154c0 -3.036 .023 -4.115 1.352 -5.633c1.671 -1.91 6.648 -1.666 6.648 -1.666s4.977 -.243 6.648 1.667c1.329 1.518 1.352 2.597 1.352 5.633s-.456 4.074 -1.352 4.944z"></path>
								<path d="M12 11.204v-2.926c0 -1.258 -.895 -2.278 -2 -2.278s-2 1.02 -2 2.278v4.722m4 -4.722c0 -1.258 .895 -2.278 2 -2.278s2 1.02 2 2.278v4.722"></path>
							</svg>
						</a>
					</li>
				</ul>
			</nav>
		</div>
	</header>
	<main id="main-content" class="max-w-screen-md px-4 pt-16 mx-auto">
		{{ content | safe }}
	</main>
</body>
</html>
